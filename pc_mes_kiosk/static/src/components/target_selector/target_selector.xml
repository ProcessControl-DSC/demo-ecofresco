<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="pc_mes_kiosk.TargetSelector">
        <div class="o_pc_mes_kiosk d-flex flex-column flex-grow-1 align-items-center justify-content-center">

            <!-- Loading -->
            <t t-if="state.loading">
                <div class="o_pc_mes_kiosk_loading d-flex flex-column align-items-center justify-content-center flex-grow-1">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted mb-3"/>
                    <span class="text-muted fs-5">Loading projects…</span>
                </div>
            </t>

            <!-- Error -->
            <t t-elif="state.error">
                <div class="o_pc_mes_kiosk_main d-flex flex-column align-items-center justify-content-center flex-grow-1 gap-4 px-4">
                    <div class="alert alert-danger text-center px-5" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <t t-esc="state.error"/>
                    </div>
                    <button class="btn btn-secondary btn-lg rounded-pill px-5" t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- Work screen: shown once the project/task is confirmed (or
                 skipped). This is the "pantalla de trabajo" that keeps
                 Pausa / Fichar salida reachable in a single tap, without
                 leaving this app or re-entering the PIN. -->
            <t t-elif="state.confirmed">
                <div class="o_pc_mes_kiosk_main d-flex flex-column flex-grow-1 w-100 align-items-center justify-content-center px-4">
                    <div class="o_pc_mes_kiosk_header text-center py-4">
                        <h2 class="fw-bold mb-1">Trabajando en</h2>
                        <p class="fs-4 mb-0" t-if="state.confirmedProjectName">
                            <t t-esc="state.confirmedProjectName"/>
                            <t t-if="state.confirmedTaskName"> — <t t-esc="state.confirmedTaskName"/></t>
                        </p>
                        <p class="fs-5 text-muted mb-0" t-else="">
                            Sin tarea asignada
                        </p>
                    </div>

                    <div class="alert alert-danger text-center px-5" role="alert" t-if="state.quickEndError">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <t t-esc="state.quickEndError"/>
                    </div>

                    <div class="o_pc_mes_kiosk_grid d-flex flex-wrap justify-content-center gap-3 p-4">
                        <button
                            class="o_pc_mes_kiosk_btn btn btn-warning btn-lg rounded-3"
                            t-on-click="quickEnd">
                            <i class="fa fa-pause me-2"/>
                            Pausa
                        </button>
                        <button
                            class="o_pc_mes_kiosk_btn btn btn-danger btn-lg rounded-3"
                            t-on-click="quickEnd">
                            <i class="fa fa-sign-out me-2"/>
                            Fichar salida
                        </button>
                    </div>
                    <p class="text-muted text-center small mb-0">
                        Para reanudar, vuelve a fichar tu PIN en el kiosco.
                    </p>
                </div>
                <div class="o_pc_mes_kiosk_footer py-4">
                    <button class="btn btn-primary btn-lg rounded-pill px-5" t-on-click="continueToGreet">
                        Continuar
                    </button>
                </div>
            </t>

            <!-- Project list -->
            <t t-elif="showingProjects">
                <div class="o_pc_mes_kiosk_main d-flex flex-column flex-grow-1 w-100">
                    <div class="o_pc_mes_kiosk_header text-center py-4">
                        <h2 class="fw-bold">Select your project</h2>
                    </div>
                    <div class="o_pc_mes_kiosk_grid d-flex flex-wrap justify-content-center gap-3 p-4 overflow-auto">
                        <t t-foreach="state.projects" t-as="project" t-key="project.id">
                            <button
                                class="o_pc_mes_kiosk_btn btn btn-primary btn-lg rounded-3"
                                t-on-click="() => this.onProjectTap(project.id)">
                                <t t-esc="project.name"/>
                            </button>
                        </t>
                        <t t-if="!state.projects.length">
                            <div class="text-muted fst-italic">No projects available.</div>
                        </t>
                    </div>
                </div>
                <div class="o_pc_mes_kiosk_footer py-4">
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5" t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- Task list (after project selected) -->
            <t t-elif="showingTasks">
                <div class="o_pc_mes_kiosk_main d-flex flex-column flex-grow-1 w-100">
                    <div class="o_pc_mes_kiosk_header text-center py-4">
                        <h2 class="fw-bold">Select your task</h2>
                        <p class="text-muted mb-0">
                            <t t-esc="selectedProjectName"/>
                        </p>
                    </div>
                    <div class="o_pc_mes_kiosk_grid d-flex flex-wrap justify-content-center gap-3 p-4 overflow-auto">
                        <t t-foreach="visibleTasks" t-as="task" t-key="task.id">
                            <button
                                class="o_pc_mes_kiosk_btn btn btn-success btn-lg rounded-3"
                                t-on-click="() => this.selectTask(task.id)">
                                <t t-esc="task.name"/>
                            </button>
                        </t>
                        <t t-if="!visibleTasks.length">
                            <div class="text-muted fst-italic py-3">No tasks for this project.</div>
                        </t>
                    </div>
                </div>
                <div class="o_pc_mes_kiosk_footer d-flex gap-3 justify-content-center py-4">
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5" t-on-click="backToProjects">
                        <i class="oi oi-chevron-left me-2"/>
                        Back
                    </button>
                    <!-- Allow confirming with just the project when no task needed -->
                    <button class="btn btn-outline-primary btn-lg rounded-pill px-5"
                        t-on-click="() => this.confirmProject(state.selectedProjectId)">
                        Project only
                    </button>
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5" t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- Saving feedback -->
            <t t-if="state.saving">
                <div class="o_pc_mes_kiosk_saving_overlay position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                    <div class="bg-white rounded-3 p-5 shadow text-center">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3"/>
                        <p class="fs-5 mb-0">Saving…</p>
                    </div>
                </div>
            </t>

        </div>
    </t>

</templates>
