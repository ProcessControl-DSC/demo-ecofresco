<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="pc_mes_kiosk_res_config_settings_view_form" model="ir.ui.view">
        <field name="name">pc.mes.kiosk.res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_attendance.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='hr_attendance']" position="inside">
                <block title="MES Kiosk — Project Imputation" name="pc_mes_kiosk_block">
                    <setting
                        string="Imputation Prompt Timing"
                        help="Choose whether operators select a project/task when clocking in or out."
                    >
                        <field name="pc_kiosk_mode" />
                    </setting>
                    <setting
                        string="Show Project Selector"
                        help="Display a project picker in the kiosk imputation screen."
                    >
                        <field name="pc_kiosk_show_project" />
                    </setting>
                    <setting
                        string="Show Task Selector"
                        help="Display a task picker in the kiosk imputation screen."
                    >
                        <field name="pc_kiosk_show_task" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
