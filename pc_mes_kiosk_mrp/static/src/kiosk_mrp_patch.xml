<templates xml:space="preserve">

    <!--
        Extends the native kiosk template to add the Manufacturing (MRP) screen
        slot alongside the existing mes_target screen inserted by pc_mes_kiosk.

        We inherit the same root template (hr_attendance.public_kiosk_app) and
        append our 'mes_mrp' t-if block after the 'mes_target' block that was
        already added by pc_mes_kiosk/static/src/kiosk_patch.xml.

        Load order: Odoo processes assets in dependency order, so pc_mes_kiosk's
        patch runs first (adds mes_target block), and this patch runs second
        (adds mes_mrp block after it).
    -->
    <t t-inherit="hr_attendance.public_kiosk_app" t-inherit-mode="extension">

        <xpath expr="//t[@t-if=&quot;this.state.active_display === 'mes_target'&quot;]" position="after">
            <t t-if="this.state.active_display === 'mes_mrp'">
                <PcMesMrpScreen
                    employeeId="_pcMesEmployeeId"
                    onDone="() => this.switchDisplay('greet')"
                    onSkip="() => this.switchDisplay('greet')"
                />
            </t>
        </xpath>

    </t>

</templates>
