<templates xml:space="preserve">

    <t t-name="pc_mes_kiosk_mrp.MrpScreen">
        <div class="o_pc_mes_kiosk d-flex flex-column flex-grow-1 align-items-center justify-content-center">

            <!-- ── Loading ─────────────────────────────────────────────── -->
            <t t-if="state.loading">
                <div class="o_pc_mes_kiosk_loading d-flex flex-column align-items-center justify-content-center flex-grow-1">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted mb-3"/>
                    <span class="text-muted fs-5">Loading manufacturing orders…</span>
                </div>
            </t>

            <!-- ── Global error ────────────────────────────────────────── -->
            <t t-elif="state.error and state.step === 'mo_list'">
                <div class="o_pc_mes_kiosk_main d-flex flex-column align-items-center justify-content-center flex-grow-1 gap-4 px-4">
                    <div class="alert alert-danger text-center px-5" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <t t-esc="state.error"/>
                    </div>
                    <button class="btn btn-secondary btn-lg rounded-pill px-5" t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- ── Step 1: MO list ─────────────────────────────────────── -->
            <t t-elif="state.step === 'mo_list'">
                <div class="o_pc_mes_kiosk_main d-flex flex-column flex-grow-1 w-100">
                    <div class="o_pc_mes_kiosk_header text-center py-4">
                        <h2 class="fw-bold">
                            <i class="fa fa-industry me-2"/>
                            Select Manufacturing Order
                        </h2>
                    </div>
                    <div class="o_pc_mes_kiosk_grid d-flex flex-wrap justify-content-center gap-3 p-4 overflow-auto">
                        <t t-foreach="state.productions" t-as="mo" t-key="mo.id">
                            <button
                                class="o_pc_mes_kiosk_btn o_pc_mes_mrp_mo_btn btn btn-primary btn-lg rounded-3"
                                t-on-click="() => this.selectMo(mo)">
                                <div class="fw-bold"><t t-esc="mo.name"/></div>
                                <div class="small mt-1 opacity-75">
                                    <t t-esc="mo.product"/>
                                </div>
                                <div class="small opacity-50">
                                    <t t-esc="mo.qty"/> <t t-esc="mo.uom"/>
                                </div>
                            </button>
                        </t>
                        <t t-if="!state.productions.length">
                            <div class="text-muted fst-italic py-3">
                                No active manufacturing orders.
                            </div>
                        </t>
                    </div>
                </div>
                <div class="o_pc_mes_kiosk_footer py-4">
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5" t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- ── Step 2: MO detail (formula + WO list) ──────────────── -->
            <t t-elif="state.step === 'mo_detail'">
                <div class="o_pc_mes_kiosk_main d-flex flex-column flex-grow-1 w-100">
                    <div class="o_pc_mes_kiosk_header text-center py-4">
                        <h2 class="fw-bold">
                            <t t-esc="state.selectedMo.name"/>
                        </h2>
                        <p class="text-muted mb-0">
                            <t t-esc="state.selectedMo.product"/>
                            — <t t-esc="state.selectedMo.qty"/> <t t-esc="state.selectedMo.uom"/>
                        </p>
                    </div>

                    <div class="d-flex flex-column flex-lg-row flex-grow-1 overflow-auto gap-3 p-3">

                        <!-- Formula (BOM components) -->
                        <div class="o_pc_mes_mrp_formula_panel card flex-lg-grow-1">
                            <div class="card-header fw-bold">
                                <i class="fa fa-list me-2"/>
                                Formula
                            </div>
                            <div class="card-body p-0">
                                <t t-if="state.formulaLoading">
                                    <div class="d-flex align-items-center justify-content-center py-4">
                                        <i class="fa fa-spinner fa-spin fa-2x text-muted"/>
                                    </div>
                                </t>
                                <t t-elif="state.formula.length">
                                    <table class="table table-sm table-striped mb-0">
                                        <thead>
                                            <tr>
                                                <th>Component</th>
                                                <th class="text-end">Qty</th>
                                                <th>UoM</th>
                                                <th>Lot</th>
                                                <th>Expiry</th>
                                                <th>Weighing</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.formula" t-as="comp" t-key="comp_index">
                                                <tr>
                                                    <td><t t-esc="comp.product"/></td>
                                                    <td class="text-end"><t t-esc="comp.qty"/></td>
                                                    <td><t t-esc="comp.uom"/></td>
                                                    <td>
                                                        <t t-if="comp.lot">
                                                            <span class="badge bg-secondary">
                                                                <t t-esc="comp.lot"/>
                                                            </span>
                                                        </t>
                                                        <t t-else="">—</t>
                                                    </td>
                                                    <td>
                                                        <t t-if="comp.expiration_date">
                                                            <span class="badge bg-warning text-dark">
                                                                <t t-esc="comp.expiration_date"/>
                                                            </span>
                                                        </t>
                                                        <t t-else="">—</t>
                                                    </td>
                                                    <td>
                                                        <t t-if="comp.weighed_qty">
                                                            <span class="badge bg-success p-2">
                                                                <i class="fa fa-check-circle me-1"/>
                                                                Weighed: <t t-esc="comp.weighed_qty"/> <t t-esc="comp.uom"/>
                                                                <t t-if="comp.lot">
                                                                    (<t t-esc="comp.lot"/>)
                                                                </t>
                                                            </span>
                                                        </t>
                                                        <t t-else="">
                                                            <button
                                                                class="o_pc_mes_mrp_weigh_btn btn btn-primary"
                                                                t-att-disabled="state.weighingProductId === comp.product_id"
                                                                t-on-click="() => this.weighComponent(comp)">
                                                                <t t-if="state.weighingProductId === comp.product_id">
                                                                    <i class="fa fa-spinner fa-spin me-2"/>
                                                                    Weighing…
                                                                </t>
                                                                <t t-else="">
                                                                    <i class="fa fa-balance-scale me-2"/>
                                                                    Weigh
                                                                </t>
                                                            </button>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-muted fst-italic p-3">No components found.</div>
                                </t>
                            </div>
                        </div>

                        <!-- Work order list -->
                        <div class="o_pc_mes_mrp_wo_panel d-flex flex-column gap-2">
                            <div class="fw-bold text-muted small text-uppercase ps-1 mb-1">
                                Work Orders
                            </div>
                            <t t-foreach="state.selectedMo.workorders" t-as="wo" t-key="wo.id">
                                <button
                                    class="o_pc_mes_kiosk_btn o_pc_mes_mrp_wo_btn btn btn-success btn-lg rounded-3"
                                    t-on-click="() => this.selectWorkorder(wo)">
                                    <div class="fw-bold"><t t-esc="wo.name"/></div>
                                    <div class="small mt-1 opacity-75">
                                        <t t-esc="wo.workcenter"/>
                                    </div>
                                </button>
                            </t>
                            <t t-if="!state.selectedMo.workorders.length">
                                <div class="text-muted fst-italic py-2">
                                    No open work orders.
                                </div>
                            </t>
                        </div>

                    </div>

                    <!-- Error in this step -->
                    <t t-if="state.error">
                        <div class="alert alert-danger mx-3 mb-0">
                            <i class="fa fa-exclamation-triangle me-2"/>
                            <t t-esc="state.error"/>
                        </div>
                    </t>
                </div>

                <div class="o_pc_mes_kiosk_footer d-flex gap-3 justify-content-center py-4">
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5"
                        t-on-click="backToMoList">
                        <i class="oi oi-chevron-left me-2"/>
                        Back
                    </button>
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5"
                        t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- ── Step 3: Work order active (weighing + confirm) ──────── -->
            <t t-elif="state.step === 'wo_active'">
                <div class="o_pc_mes_kiosk_main d-flex flex-column flex-grow-1 w-100">
                    <div class="o_pc_mes_kiosk_header text-center py-4">
                        <h2 class="fw-bold">
                            <t t-esc="state.selectedWorkorder.name"/>
                        </h2>
                        <p class="text-muted mb-0">
                            <t t-esc="state.selectedMo.name"/>
                            — <t t-esc="state.selectedWorkorder.workcenter"/>
                        </p>
                    </div>

                    <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 gap-4 p-4">

                        <!-- Weighing section -->
                        <div class="o_pc_mes_mrp_scale_card card text-center p-4 w-100" style="max-width: 480px;">
                            <div class="card-body">
                                <div class="fw-bold fs-5 mb-3">
                                    <i class="fa fa-balance-scale me-2"/>
                                    Weighing
                                </div>

                                <t t-if="state.simulatedWeight">
                                    <div class="display-4 fw-bold text-primary mb-2">
                                        <t t-esc="state.simulatedWeight"/> kg
                                    </div>
                                    <div class="text-muted small mb-3">(simulated reading)</div>
                                </t>
                                <t t-else="">
                                    <div class="display-4 fw-bold text-muted mb-2">— kg</div>
                                    <div class="text-muted small mb-3">Place product on scale</div>
                                </t>

                                <!--
                                    TODO (phase 2): replace "Simulate weighing" with a real scale
                                    integration.  Options:
                                      a) WebSerial API → read RS-232/USB scale directly in browser
                                      b) Local bridge service on the kiosk machine that exposes the
                                         scale weight on a local HTTP endpoint
                                      c) Barcode scan of a pre-printed weight label
                                    The button below keeps the UX flow complete for demos.
                                -->
                                <button
                                    class="btn btn-outline-secondary btn-lg rounded-pill px-4"
                                    t-on-click="simulateWeighing">
                                    <i class="fa fa-refresh me-2"/>
                                    Simulate weighing
                                </button>
                            </div>
                        </div>

                        <!-- Error -->
                        <t t-if="state.error">
                            <div class="alert alert-danger text-center px-4">
                                <i class="fa fa-exclamation-triangle me-2"/>
                                <t t-esc="state.error"/>
                            </div>
                        </t>

                        <!-- Start / Confirm buttons -->
                        <t t-if="!state.workorderStarted">
                            <button
                                class="btn btn-warning btn-lg rounded-pill px-5"
                                t-att-disabled="state.starting"
                                t-on-click="startWorkorder">
                                <t t-if="state.starting">
                                    <i class="fa fa-spinner fa-spin me-2"/>
                                    Starting…
                                </t>
                                <t t-else="">
                                    <i class="fa fa-play me-2"/>
                                    Start work order
                                </t>
                            </button>
                        </t>
                        <t t-else="">
                            <div class="alert alert-success text-center px-5">
                                <i class="fa fa-clock-o me-2"/>
                                Work order started — time is being logged.
                            </div>
                            <button
                                class="btn btn-danger btn-lg rounded-pill px-5"
                                t-att-disabled="state.stopping"
                                t-on-click="finishWorkorder">
                                <t t-if="state.stopping">
                                    <i class="fa fa-spinner fa-spin me-2"/>
                                    Finishing…
                                </t>
                                <t t-else="">
                                    <i class="fa fa-stop me-2"/>
                                    Confirm / Finish
                                </t>
                            </button>
                        </t>

                    </div>
                </div>

                <div class="o_pc_mes_kiosk_footer d-flex gap-3 justify-content-center py-4">
                    <t t-if="!state.workorderStarted">
                        <button class="btn btn-outline-secondary btn-lg rounded-pill px-5"
                            t-on-click="backToMoDetail">
                            <i class="oi oi-chevron-left me-2"/>
                            Back
                        </button>
                    </t>
                    <button class="btn btn-outline-secondary btn-lg rounded-pill px-5"
                        t-on-click="skip">
                        Skip
                    </button>
                </div>
            </t>

            <!-- ── Saving overlay ──────────────────────────────────────── -->
            <t t-if="state.starting or state.stopping">
                <div class="o_pc_mes_kiosk_saving_overlay position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center">
                    <div class="bg-white rounded-3 p-5 shadow text-center">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3"/>
                        <p class="fs-5 mb-0">
                            <t t-if="state.stopping">Finishing work order…</t>
                            <t t-else="">Starting work order…</t>
                        </p>
                    </div>
                </div>
            </t>

        </div>
    </t>

</templates>
